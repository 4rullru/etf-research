---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="max-w-4xl mx-auto p-4">
			<h1 class="text-3xl font-bold my-8">📈 ETF 데이터 분석 연구소</h1>
			<p class="mb-8">국내 반도체, 커버드콜, 배당 성장 ETF를 정량적으로 분석합니다.</p>
			
			<section>
				<ul class="grid gap-6">
					{posts.map((post) => (
						<li class="border p-4 rounded-lg hover:shadow-lg transition">
							<a href={`/etf-research/blog/${post.slug}/`}>
								<h4 class="text-xl font-bold">{post.data.title}</h4>
								<p class="text-gray-500">{post.data.description}</p>
								<time class="text-sm">{post.data.pubDate.toLocaleDateString('ko-KR')}</time>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

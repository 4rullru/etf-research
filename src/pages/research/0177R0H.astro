---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="TIGER 반도체TOP10커버드콜액티브 ETF 분석">
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/moonspam/NanumSquare@2.0/nanumsquare.css">
<style>
:root {
  --primary: #2563EB;
  --primary-light: #EFF6FF;
  --success: #059669;
  --success-light: #ECFDF5;
  --danger: #DC2626;
  --danger-light: #FEF2F2;
  --warning: #D97706;
  --warning-light: #FFFBEB;
  --text-main: #111827;
  --text-muted: #4B5563;
  --bg-body: #F9FAFB;
  --bg-card: #FFFFFF;
  --border: #E5E7EB;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
	font-family: 'NanumSquare','Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
  color: var(--text-main);
  background-color: var(--bg-body);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.blog {
  max-width: 768px;
  margin: 0 auto;
  padding: 2.5rem 1.25rem;
}

/* Hero Section */
.hero {
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  border-radius: 16px;
  padding: 2.5rem 2rem;
  color: white;
  margin-bottom: 2.5rem;
  box-shadow: 0 10px 25px rgba(37, 99, 235, 0.2);
}
.hero-badge {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(4px);
  color: white;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 1.25rem;
  display: inline-block;
}
.hero-title {
  color : white;
  font-size: 26px;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 0.75rem;
  word-break: keep-all;
}
.hero-sub {
  font-size: 15px;
  opacity: 0.9;
  margin-bottom: 2rem;
  word-break: keep-all;
}
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
.stat {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 1.25rem 1rem;
  text-align: center;
  border: 1px solid rgba(255, 255, 255, 0.15);
}
.stat-label {
  font-size: 13px;
  opacity: 0.85;
  margin-bottom: 6px;
}
.stat-val {
  font-size: 22px;
  font-weight: 700;
  color: #FCD34D;
}
.stat-val.normal { color: white; }

/* Sections & Cards */
.section { margin-bottom: 3.5rem; }
.section-label {
  color: var(--primary);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.05em;
  margin-bottom: 0.5rem;
}
.section-title {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 1.5rem;
  color: var(--text-main);
  word-break: keep-all;
}
.card {
  background: var(--bg-card);
  border-radius: 16px;
  padding: 2rem;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
  border: 1px solid var(--border);
}
.prose {
  font-size: 15px;
  color: var(--text-muted);
  line-height: 1.8;
  word-break: keep-all;
}

/* Highlight Box */
.highlight-box {
  background: var(--primary-light);
  border-left: 4px solid var(--primary);
  padding: 1.25rem 1.5rem;
  border-radius: 0 12px 12px 0;
  margin-top: 1.5rem;
  font-size: 14.5px;
  color: var(--text-muted);
  line-height: 1.7;
}

/* Steps */
.steps { display: flex; flex-direction: column; }
.step {
  display: flex;
  gap: 1.25rem;
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--border);
}
.step:last-child { border-bottom: none; padding-bottom: 0; }
.step:first-child { padding-top: 0; }
.step-num {
  width: 34px; height: 34px;
  background: var(--primary); color: white;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 15px; flex-shrink: 0;
}
.step-title { font-weight: 700; font-size: 17px; margin-bottom: 6px; color: var(--text-main); }
.step-desc { font-size: 15px; color: var(--text-muted); word-break: keep-all; }

/* Charts */
.chart-wrap { position: relative; width: 100%; margin-top: 1rem; }
.legend { display: flex; flex-wrap: wrap; gap: 10px 20px; margin-bottom: 16px; font-size: 13px; color: var(--text-muted); justify-content: center; }
.legend span { display: flex; align-items: center; gap: 6px; }
.legend-sq { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; }

/* Grid & Compare */
.compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 1.5rem; }
.compare-card { background: var(--bg-card); border-radius: 16px; padding: 1.75rem; border: 1px solid var(--border); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); position: relative; }
.compare-card.featured { border: 2px solid var(--primary); }
.compare-badge { position: absolute; top: -14px; right: 20px; background: var(--primary); color: white; font-size: 12px; padding: 6px 14px; border-radius: 20px; font-weight: 700; box-shadow: 0 2px 4px rgba(37,99,235,0.2); }
.compare-name { font-size: 18px; font-weight: 700; margin-bottom: 1.5rem; text-align: center; color: var(--text-main); line-height: 1.3; }
.compare-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px dashed var(--border); font-size: 14.5px; }
.compare-row:last-child { border-bottom: none; padding-bottom: 0; }
.compare-key { color: var(--text-muted); }
.compare-val { font-weight: 600; color: var(--text-main); }
.compare-val.good { color: var(--success); }
.compare-val.warn { color: var(--warning); }

/* Pros Cons & Target Lists */
.pros-cons, .target-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 1.5rem; }
.box { border-radius: 16px; padding: 1.5rem; }
.pro-box, .target-yes { background: var(--success-light); border: 1px solid #A7F3D0; }
.con-box, .target-no { background: var(--danger-light); border: 1px solid #FECACA; }
.box-head { font-weight: 700; font-size: 16px; margin-bottom: 16px; display: flex; align-items: center; gap: 6px; }
.pro-box .box-head, .target-yes .box-head { color: var(--success); }
.con-box .box-head, .target-no .box-head { color: var(--danger); }
.box-item { font-size: 14px; color: var(--text-muted); margin-bottom: 10px; padding-left: 22px; position: relative; line-height: 1.6; word-break: keep-all; }
.box-item:last-child { margin-bottom: 0; }
.box-item::before { position: absolute; left: 0; top: 0; font-weight: bold; font-size: 15px; }
.pro-box .box-item::before, .target-yes .box-item::before { content: "✓"; color: var(--success); }
.con-box .box-item::before, .target-no .box-item::before { content: "✗"; color: var(--danger); }

/* Verdict */
.verdict { background: var(--primary-light); border: 1px solid #BFDBFE; border-radius: 16px; padding: 1.75rem; margin-top: 2rem; }
.verdict-title { font-weight: 700; color: var(--primary); margin-bottom: 10px; font-size: 17px; }
.verdict-body { font-size: 15px; color: var(--text-muted); line-height: 1.7; word-break: keep-all; }

/* Utilities */
.divider { border: none; height: 1px; background: var(--border); margin: 3.5rem 0; }

@media(max-width: 640px) {
  .stats-row { grid-template-columns: 1fr; gap: 0.75rem; }
  .compare-grid, .pros-cons, .target-grid { grid-template-columns: 1fr; }
  .hero { padding: 2rem 1.5rem; }
  .card { padding: 1.5rem; }
}
</style>

<div class="blog">
  <h2 class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden">TIGER 반도체TOP10커버드콜액티브 ETF 초보자 가이드 블로그 포스트</h2>

  <div class="hero">
    <span class="hero-badge">2026년 신규 상장 ETF 분석</span>
    <h1 class="hero-title">매달 월급처럼 배당받는 반도체 ETF?<br>TIGER 반도체TOP10 커버드콜 완전 분석</h1>
    <p class="hero-sub">삼성전자·SK하이닉스의 변동성을 수익으로 바꾸는 ETF — 초보자도 이해하는 3분 가이드</p>
